# ─────────────────────────────────────────────────────────────────────────────
# VERO SafeGuard — Environment Variables Template
#
# Copy this file to .env before running Docker:
#   cp .env.example .env
#
# The .env file is git-ignored and will NOT be committed.
# These defaults work for local Docker runs without any edits.
# ─────────────────────────────────────────────────────────────────────────────

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=vero_secure_2026
POSTGRES_DB=vero
DATABASE_URL=postgresql://postgres:vero_secure_2026@db:5432/vero

# Razorpay (optional — app falls back to direct purchase if not set)
# Get test keys from https://dashboard.razorpay.com
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Admin API key — protects all /dashboards/admin/* endpoints
ADMIN_API_KEY=vero_admin_key_2026

# Frontend build variables (baked into the React build at docker compose up --build)
VITE_API_URL=/api
VITE_ADMIN_API_KEY=vero_admin_key_2026
VITE_ADMIN_USER=admin@vero
VITE_ADMIN_PASS=admin1234
