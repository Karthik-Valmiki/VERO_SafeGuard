# VERO — Environment Configuration
# ────────────────────────────────────────────────────────────────────────────────────────────
# For Docker: values are already hardcoded in docker-compose.yml as this is demo model
# Just run:  docker compose up --build
# No .env file needed for Docker.
#
# For local dev (running backend with uvicorn directly):
# Copy this file to backend/.env and set DATABASE_URL to your local Postgres.
# ────────────────────────────────────────────────────────────────────────────────────────────

POSTGRES_USER=postgres
POSTGRES_PASSWORD=vero_secure_2026
POSTGRES_DB=vero

# Points to the Docker db service (used inside docker-compose network)
DATABASE_URL=postgresql://postgres:vero_secure_2026@db:5432/vero

# ── Razorpay Test Mode (optional) ────────────────────────────────────────────
# Get free test keys from https://dashboard.razorpay.com → Settings → API Keys
# Leave blank to use direct-purchase fallback (no Razorpay modal).
RAZORPAY_KEY_ID=rzp_test_Sb3L7VNU1p6fVQ
RAZORPAY_KEY_SECRET=aZ3evTMqeU5EEcik9xZuEOPW
