docker-compose.override.yml

# OS files
.DS_Store
Thumbs.db

# Project specific
backend/app/db/*.db
backend/app/db/*.sqlite

# Pre-trained ML models are committed intentionally so cloners get them immediately.
# Do NOT add *.pkl to this file.
# To retrain: python backend/scripts/train_models.py
